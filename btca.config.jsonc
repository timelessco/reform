{
  "$schema": "https://btca.dev/btca.schema.json",
  "dataDirectory": ".btca",
  "resources": [
    {
      "type": "git",
      "name": "plate",
      "url": "https://github.com/udecode/plate",
      "branch": "main",
    },
    {
      "type": "git",
      "name": "tanstack-db",
      "url": "https://github.com/tanstack/db",
      "branch": "main"
    },
    {
      "type": "git",
      "name": "tanstack-ai",
      "url": "https://github.com/tanstack/ai",
      "branch": "main"
    }
  ],
  "model": "glm-5-turbo",
  "provider": "openai-compat",
  "providerOptions": {
    "openai-compat": {
      "baseURL": "https://api.z.ai/api/coding/paas/v4",
      "name": "z.ai",
    },
  },
}
