{
  "name": "start-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "caddy run --config Caddyfile & sleep 1 && printf '\\n  ➜  HTTP/2: https://localhost:%s\\n\\n' \"${CADDY_PORT:-3001}\" && vite dev --port ${PORT:-3000}",
    "dev:auto": "p=3000; while lsof -iTCP:$p -sTCP:LISTEN >/dev/null 2>&1; do p=$((p+1)); done; PORT=$p CADDY_PORT=$((p+1)) bun dev",
    "dev:worktree": "cp -f /Users/vijayabaskar/work/better-form/.env .env && bun dev:auto",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "oxlint && knip --strict --use-tsconfig-files",
    "lint:fix": "oxlint --fix",
    "knip": "knip --strict --use-tsconfig-files",
    "knip:fix": "knip --fix --use-tsconfig-files",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check",
    "check": "ultracite check",
    "check:fix": "bun run check --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "build:embed": "esbuild src/embed/embed-popup.ts --bundle --minify --outfile=public/embed/popup.js --target=es2020 --format=iife",
    "build": "bun run build:embed && NODE_OPTIONS='--max-old-space-size=8192' vite build",
    "start": "node .output/server/index.mjs",
    "fix": "ultracite fix"
  },
